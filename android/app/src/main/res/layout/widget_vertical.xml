<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_v"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- ── سەرەوە: ناوی ئەپ ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Wisdom Gates"
        android:textColor="#1A1A1A"
        android:textSize="12sp"
        android:textStyle="bold"
        android:alpha="0.6"
        android:layout_marginBottom="12dp" />

    <!-- ── تاسک ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/icon_bg_orange"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☑"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tasks"
            android:textColor="#5C5C5C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_tasks_v"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#E65100"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── نۆت ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/icon_bg_blue"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notes"
            android:textColor="#5C5C5C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_notes_v"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── ریمایندەر ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:background="@drawable/icon_bg_green"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reminders"
            android:textColor="#5C5C5C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_reminders_v"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── خەتی جیاکەر ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A1A"
        android:alpha="0.08"
        android:layout_marginBottom="10dp" />

    <!-- ── لەیبڵی خوارەوە ── -->
    <TextView
        android:id="@+id/tv_label_v"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="✨ Loading..."
        android:textColor="#2C2C2C"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.5"
        android:maxLines="3"
        android:ellipsize="end"
        android:alpha="0.7"
        android:gravity="top" />

</LinearLayout>