<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_h"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- ── ڕیسی سەرەوە: ناو + ژمارەکان ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✨ Wisdom Gates"
            android:textColor="#1A1A1A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:alpha="0.5" />

        <!-- تاسک -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_background_orange"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☑"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tv_tasks_h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#E65100"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- نۆت -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_background_blue"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tv_notes_h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#1565C0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ریمایندەر -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/chip_background_green"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />
            <TextView
                android:id="@+id/tv_reminders_h"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── لەیبڵی خوارەوە ── -->
    <TextView
        android:id="@+id/tv_label_h"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="✨ Loading..."
        android:textColor="#2C2C2C"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.4"
        android:maxLines="2"
        android:ellipsize="end"
        android:alpha="0.75" />

</LinearLayout>